# Aliyun SJG single-VM environment template.
# Copy this file to `.env` on the Aliyun ECS and fill secret values from the
# existing AWS SJG `knowhere-secrets` Secret unless the value is explicitly
# marked as an Aliyun/local replacement.

# -----------------------------------------------------------------------------
# Image and Compose bindings
# -----------------------------------------------------------------------------
KNOWHERE_IMAGE=knowhere-registry.cn-shenzhen.cr.aliyuncs.com/knowhere/knowhere:sjg-a23167bf-cn
API_HOST_BIND=127.0.0.1
API_HOST_PORT=5005
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=5432
REDIS_HOST_BIND=127.0.0.1
REDIS_HOST_PORT=6379
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# Self-hosted process control
# -----------------------------------------------------------------------------
SELF_HOSTED_RUN_DASHBOARD_MIGRATIONS=false
SELF_HOSTED_START_DASHBOARD=false
SELF_HOSTED_CREATE_STORAGE_BUCKETS=false
SELF_HOSTED_CONFIGURE_STORAGE_EVENTS=false
SELF_HOSTED_S3_EVENT_WEBHOOK_URL=https://api-sjg.knowhereto.com/api/v1/internal/s3-events

# -----------------------------------------------------------------------------
# Local database and Redis replacements for AWS SJG managed services
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=Knowhere
POSTGRES_USER=root
API_DATABASE_URL=
DASHBOARD_DATABASE_URL=
DATABASE_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=
REDIS_SSL=false
CELERY_REDIS_DATABASE=0
CELERY_REDIS_HOST=redis
CELERY_REDIS_PORT=6379
CELERY_REDIS_SSL=false
CELERY_REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND_REDIS=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Live AWS SJG config copied forward, with domain/storage adjusted for Aliyun
# -----------------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256
ALI_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions
ALL_DF_COLS=content,path,type,length,keywords,summary,know_id,tokens,connectto,addtime,page_nums
API_WEBHOOK_ENDPOINT=https://api-sjg.knowhereto.com/api/v1/internal/s3-events
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APP_DESCRIPTION=基于AI的知识库管理和智能问答系统
APP_ENV=production
APP_TITLE=Konwhere AI知识库管理系统
APP_VERSION=sjg-a23167bf
ARK_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
AWS_ACCOUNT_ID=
AWS_REGION=
CHROMEDRIVER_PATH=/usr/bin/chromedriver
CONFIG_PATH=app/core/config/config.txt
DB_SSL_MODE=disable
DEBUG=false
DEFAULT_BATCH_SIZE=32
DEFAULT_EMBEDDING_DIM=1024
DEFAULT_EPOCHS=3
DEFAULT_FOLDERS=默认目录,Supplementary_Files,Temporary_Files,templates,images,fragments
DEFAULT_THRESHOLD=0.5
DEFAULT_TOP_K=5
DS_URL=https://api.deepseek.com/v1/chat/completions
EMAILS_FROM_EMAIL=
EMAILS_FROM_NAME=AI Smart Bid
EMBEDDING_MODEL=text-embedding-v4
ENVIRONMENT=production
FONT_PATH=/usr/share/fonts
FRONTEND_URL=https://api-sjg.knowhereto.com
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
HIGH_IOU_THRESHOLD=0.9
ILOVEAPI_MAX_CONCURRENT=20
IMAGE_MODEL=qwen-vl-plus
IMAGE_MODEL_MAX=qwen-vl-max
IMG_TBL_PATTERN=TABLE_.*?_TABLE|IMAGE_.*?_IMAGE
INTERNAL_API_URL=http://127.0.0.1:5005
INTERNAL_DASHBOARD_ENDPOINT=http://127.0.0.1:3000
KB_TERM=KB_DATA
KB_VEC_TERM=KB_VECS
LOG_LEVEL=INFO
MAX_FILE_SIZE=104857600
MAX_IMAGE_SIZE=10485760
MESSAGE_BROKER_TYPE=aws
META_PATH=app/core/config/Meta_setting.csv
MINERU_URL=https://mineru.net/api/v4
MIN_CONFIDENCE_THRESHOLD=0.05
NORMOL_MODEL=qwen3.5-flash
OSS_ENDPOINT=https://oss-cn-guangzhou.aliyuncs.com
OSS_EVENT_VERIFY_SIGNATURE=false
PATH_IMAGE_PATTERN=.*\.(png|jpe?g|gif)$
QSTASH_CALLBACK_BASE_URL=
QSTASH_URL=https://qstash-us-east-1.upstash.io
S3_BUCKET_NAME=
S3_UPLOADS_BUCKET=
S3_RESULTS_BUCKET=
S3_TEMP_PATH=/tmp
S3_TYPE=oss
S3_REGION=cn-guangzhou
S3_USE_SSL=true
S3_ADDRESSING_STYLE=virtual
S3_ENDPOINT_URL=
S3_PRIVATE_DOMAIN=
SMTP_HOST=smtp.gmail.com
SMTP_PASSWORD=
SMTP_PORT=587
SMTP_USER=
SNS_TOPIC_ARN=
SPLIT_CHAR=/
SUPPORTED_EXTENSIONS=.doc,.docx,.pdf,.txt,.xls,.xlsx,.csv,.jpg,.jpeg,.png,.pptx,.md
TMP_PATH=/tmp/aismart_bid
USERS_DATA_PATH=/data/users
USERS_RESET_PASSWORD_TOKEN_SECRET=
USERS_VERIFY_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# Existing AWS SJG secret values to copy into Aliyun unless replaced
# -----------------------------------------------------------------------------
SECRET_KEY=
DS_KEY=
ALI_API_KEYS=
ARK_API_KEY=
GPT_API_KEY=
MINERU_API_KEYS=
ILOVEAPI_KEYS=
LOGFIRE_TOKEN=
MOESIF_APPLICATION_ID=
OSS_EVENT_CALLBACK_KEY=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
QSTASH_TOKEN=
RESEND_API_KEY=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_WEBHOOK_AUTH_TOKEN=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
WEBHOOK_MASTER_KEY=
WEBHOOK_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# Worker concurrency overrides from live AWS SJG
# -----------------------------------------------------------------------------
SUMMARY_LLM_MAX_CONCURRENT=
HEADING_LLM_MAX_CONCURRENT=
REDIS_SYNC_MAX_CONNECTIONS=
WORKER_CONCURRENCY=
