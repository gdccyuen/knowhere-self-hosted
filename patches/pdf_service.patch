+_MINERU_LOCAL_MODE = os.environ.get("MINERU_LOCAL_MODE", "false").lower() == "true"
+_MINERU_LOCAL_LANG_LIST = [
+    s.strip() for s in os.environ.get("MINERU_LOCAL_LANG_LIST", "ch").split(",") if s.strip()
+]
+_MINERU_LOCAL_BACKEND = os.environ.get("MINERU_LOCAL_BACKEND", "pipeline")
+_MINERU_LOCAL_TIMEOUT = int(os.environ.get("MINERU_LOCAL_TIMEOUT", "3600"))
 
